# ============================================
# HMN Cascade — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit your .env file to version control.

# ------------------------------------------
# Server Config
# ------------------------------------------
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3001

# ------------------------------------------
# Auth
# ------------------------------------------
ADMIN_PASSWORD=your-admin-password-here
JWT_SECRET=your-jwt-secret-here
CASCADE_API_KEY=your-cascade-api-key-here

# ------------------------------------------
# Supabase
# ------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ------------------------------------------
# AI
# ------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# ------------------------------------------
# Voice
# ------------------------------------------
DEEPGRAM_API_KEY=your-deepgram-api-key-here
VAPI_PRIVATE_KEY=your-vapi-private-key-here
VITE_VAPI_PUBLIC_KEY=your-vapi-public-key-here
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id-here

# ------------------------------------------
# Email
# ------------------------------------------
RESEND_API_KEY=re_your-resend-api-key-here
RESEND_FROM_EMAIL=assessments@yourdomain.com
RESEND_FROM_NAME=HMN Assessments

# ------------------------------------------
# Research
# ------------------------------------------
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here

# ------------------------------------------
# Graph Database
# ------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password-here
NEO4J_DATABASE=neo4j

# ------------------------------------------
# Optional
# ------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
HUMANGLUE_URL=https://your-humanglue-url.com
